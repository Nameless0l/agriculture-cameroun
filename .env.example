# Clé API Google Gemini (obligatoire) — https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Région par défaut (Centre, Littoral, Ouest, Sud, Est, Nord, Adamaoua, Extrême-Nord, Nord-Ouest, Sud-Ouest)
DEFAULT_REGION=Centre

# Modèles Gemini (gemini-2.0-flash-001 recommandé, gemini-2.0-flash-lite pour free tier)
ROOT_AGENT_MODEL=gemini-2.0-flash-001
CROPS_AGENT_MODEL=gemini-2.0-flash-001
HEALTH_AGENT_MODEL=gemini-2.0-flash-001
ECONOMIC_AGENT_MODEL=gemini-2.0-flash-001
RESOURCES_AGENT_MODEL=gemini-2.0-flash-001
WEATHER_AGENT_MODEL=gemini-2.0-flash-001

# Observabilité Langfuse (optionnel) — https://langfuse.com/
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=https://cloud.langfuse.com
